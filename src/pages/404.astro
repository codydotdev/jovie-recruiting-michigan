---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found | Jovie of Ann Arbor"
  description="The page you're looking for doesn't exist."
>
  <Nav />
  <main>
    <section style="background-color: #1A475E; min-height: 100dvh; display: flex; align-items: center; padding-top: 70px;">
      <div class="container" style="text-align: center;">
        <p style="font-family: var(--font-display); font-weight: 800; font-size: 6rem; color: #F26B21; margin: 0 0 1rem 0; line-height: 1;">404</p>
        <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.75rem, 3vw, 2.5rem); color: #FAFAF8; margin: 0 0 1rem 0;">Page Not Found</h1>
        <p style="font-size: 1.0625rem; color: #A8C4CC; margin: 0 0 2.5rem 0;">The page you're looking for doesn't exist. Let's get you back on track.</p>
        <a href="/" class="btn-primary" style="font-size: 1.0625rem; padding: 1rem 2rem;">Back to Home</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
