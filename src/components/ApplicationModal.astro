---
const WEB3FORMS_KEY = "d5e9c407-a73b-4fd8-b123-7e5e15f6d3d5";
---

<div
  id="application-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  style="
    display: none;
    position: fixed;
    inset: 0;
    z-index: 500;
    background-color: rgba(15, 35, 48, 0.82);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  "
>
  <div
    id="modal-panel"
    style="
      background-color: #FFFFFF;
      border-radius: 1.5rem;
      width: 100%;
      max-width: 32rem;
      max-height: 90dvh;
      overflow-y: auto;
      position: relative;
      box-shadow: 0 24px 64px rgba(15, 35, 48, 0.35);
      transform: translateY(20px);
      opacity: 0;
      transition: transform 0.3s ease-out, opacity 0.3s ease-out;
    "
  >
    <!-- Header bar -->
    <div
      style="
        background-color: #1A475E;
        border-radius: 1.5rem 1.5rem 0 0;
        padding: 1.75rem 2rem 1.5rem;
        position: relative;
      "
    >
      <p
        style="
          font-family: var(--font-label);
          font-weight: 600;
          font-size: 0.7rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color: #8CD5DF;
          margin: 0 0 0.5rem 0;
        "
      >
        Now Hiring in Southeast Michigan
      </p>
      <h2
        id="modal-title"
        style="
          font-family: var(--font-display);
          font-weight: 700;
          font-size: 1.5rem;
          letter-spacing: -0.02em;
          color: #FAFAF8;
          margin: 0;
          line-height: 1.2;
        "
      >
        Apply to Join Jovie of Ann Arbor
      </h2>

      <button
        id="modal-close"
        aria-label="Close application form"
        style="
          position: absolute;
          top: 1.25rem;
          right: 1.25rem;
          background: rgba(255,255,255,0.12);
          border: none;
          border-radius: 50%;
          width: 2rem;
          height: 2rem;
          cursor: pointer;
          display: flex;
          align-items: center;
          justify-content: center;
          color: #FAFAF8;
          transition: background-color 0.2s;
          flex-shrink: 0;
        "
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="1" y1="1" x2="13" y2="13"/>
          <line x1="13" y1="1" x2="1" y2="13"/>
        </svg>
      </button>
    </div>

    <!-- Form body -->
    <div style="padding: 2rem;">

      <!-- Success state -->
      <div
        id="modal-success"
        style="display: none; text-align: center; padding: 1rem 0 0.5rem;"
      >
        <div style="margin-bottom: 1rem;">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none" style="margin: 0 auto;">
            <circle cx="26" cy="26" r="26" fill="#EBF7F9"/>
            <path d="M15 26l8 8 14-14" stroke="#1A475E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; color: #1A2E38; margin: 0 0 0.75rem;">
          Application Received
        </h3>
        <p style="font-size: 0.9375rem; line-height: 1.7; color: #4A6572; margin: 0 0 1.75rem;">
          Thanks for applying to Jovie of Ann Arbor. A member of our local team will reach out to you within one business day to schedule a conversation.
        </p>
        <button
          id="modal-success-close"
          class="btn-primary"
          style="width: 100%;"
        >
          Done
        </button>
      </div>

      <script src="https://web3forms.com/client/script.js" async defer></script>

      <form
        id="application-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        enctype="multipart/form-data"
        novalidate
      >
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="New Nanny/Babysitter Application: Jovie of Ann Arbor" />
        <input type="hidden" name="redirect" value="false" />
        <input type="hidden" name="from_name" value="Jovie Recruiting Michigan" />
        <input type="checkbox" name="botcheck" style="display:none;" />

        <div style="display: flex; flex-direction: column; gap: 1.125rem;">

          <!-- Name -->
          <div>
            <label for="app-name" style="display: block; font-family: var(--font-label); font-weight: 600; font-size: 0.8125rem; color: #1A2E38; margin-bottom: 0.375rem;">
              Full Name <span style="color: #F26B21;">*</span>
            </label>
            <input type="text" id="app-name" name="name" required placeholder="Jane Smith" class="app-input" />
          </div>

          <!-- Phone -->
          <div>
            <label for="app-phone" style="display: block; font-family: var(--font-label); font-weight: 600; font-size: 0.8125rem; color: #1A2E38; margin-bottom: 0.375rem;">
              Phone Number <span style="color: #F26B21;">*</span>
            </label>
            <input type="tel" id="app-phone" name="phone" required placeholder="(734) 555-0100" class="app-input" />
          </div>

          <!-- Email -->
          <div>
            <label for="app-email" style="display: block; font-family: var(--font-label); font-weight: 600; font-size: 0.8125rem; color: #1A2E38; margin-bottom: 0.375rem;">
              Email Address <span style="color: #F26B21;">*</span>
            </label>
            <input type="email" id="app-email" name="email" required placeholder="jane@email.com" class="app-input" />
          </div>

          <!-- Position interest -->
          <div>
            <label for="app-position" style="display: block; font-family: var(--font-label); font-weight: 600; font-size: 0.8125rem; color: #1A2E38; margin-bottom: 0.375rem;">
              Position Interest <span style="color: #F26B21;">*</span>
            </label>
            <select id="app-position" name="position" required class="app-input" style="appearance: none; cursor: pointer;">
              <option value="" disabled selected>Select a position</option>
              <option value="Full-Time Nanny">Full-Time Nanny</option>
              <option value="Part-Time Nanny">Part-Time Nanny</option>
              <option value="On-Call Babysitter">On-Call Babysitter</option>
              <option value="Not sure yet">Not sure yet, open to all</option>
            </select>
          </div>

          <!-- Availability -->
          <div>
            <label for="app-availability" style="display: block; font-family: var(--font-label); font-weight: 600; font-size: 0.8125rem; color: #1A2E38; margin-bottom: 0.375rem;">
              Tell us about your availability
            </label>
            <textarea id="app-availability" name="availability" rows="3" placeholder="e.g. Available weekday mornings and some evenings." class="app-input" style="resize: vertical; min-height: 80px;"></textarea>
          </div>

          <!-- SMS consent checkbox -->
          <div style="border: 1.5px solid #E5E9EB; border-radius: 0.5rem; padding: 1rem; background: #FAFAF8;">
            <label style="display: flex; gap: 0.75rem; align-items: flex-start; cursor: pointer;">
              <input
                type="checkbox"
                id="app-sms-consent"
                name="sms_consent"
                required
                style="
                  width: 1.125rem;
                  height: 1.125rem;
                  flex-shrink: 0;
                  margin-top: 0.125rem;
                  accent-color: #1A475E;
                  cursor: pointer;
                "
              />
              <span style="font-size: 0.8rem; line-height: 1.6; color: #4A6572;">
                By checking the box, I agree to receive text messages from Jovie sent via an autodialer, and this agreement isn't a condition of any purchase. I also agree to the Terms of Service and Privacy Policy at <a href="https://www.jovie.com/privacy-policy/" target="_blank" rel="noopener noreferrer" style="color: #1A475E; text-decoration: underline;">www.jovie.com/privacy-policy/</a>. 4 Msgs/Month. Msg &amp; Data Rates may apply. Text STOP to opt out anytime. Text Help for more information. <span style="color: #F26B21;">*</span>
              </span>
            </label>
          </div>

          <div class="h-captcha" data-captcha="true" style="margin-bottom: 0.25rem;"></div>

          <button type="submit" id="modal-submit" class="btn-primary" style="width: 100%; position: relative; margin-top: 0.25rem;">
            <span id="submit-label">Submit Application</span>
            <span id="submit-spinner" style="display:none; position: absolute; right: 1.25rem; top: 50%; transform: translateY(-50%);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="animation: spin 0.8s linear infinite;">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              </svg>
            </span>
          </button>

          <p style="font-size: 0.8rem; color: #4A6572; text-align: center; margin: 0;">
            Must be 18 or older to apply. A local team member will follow up within one business day.
          </p>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .app-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid #E5E9EB;
    border-radius: 0.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: #1A2E38;
    background: #FAFAF8;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  @keyframes spin {
    from { transform: translateY(-50%) rotate(0deg); }
    to   { transform: translateY(-50%) rotate(360deg); }
  }

  #application-modal.open {
    display: flex !important;
  }

  #application-modal.open #modal-panel {
    transform: translateY(0) !important;
    opacity: 1 !important;
  }

  #application-form input:focus,
  #application-form select:focus,
  #application-form textarea:focus {
    border-color: #1A475E;
    background: #fff;
  }
</style>

<script>
  const modal = document.getElementById('application-modal');
  const panel = document.getElementById('modal-panel');
  const closeBtn = document.getElementById('modal-close');
  const successCloseBtn = document.getElementById('modal-success-close');
  const form = document.getElementById('application-form') as HTMLFormElement;
  const successEl = document.getElementById('modal-success');
  const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;
  const submitLabel = document.getElementById('submit-label');
  const submitSpinner = document.getElementById('submit-spinner');

  function openModal() {
    modal!.classList.add('open');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      panel!.style.transform = 'translateY(0)';
      panel!.style.opacity = '1';
    });
    setTimeout(() => {
      (document.getElementById('app-name') as HTMLInputElement)?.focus();
    }, 150);
  }

  function resetForm() {
    form.reset();
    form.style.display = 'block';
    successEl!.style.display = 'none';
  }

  function closeModal() {
    panel!.style.transform = 'translateY(20px)';
    panel!.style.opacity = '0';
    setTimeout(() => {
      modal!.classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(resetForm, 300);
    }, 300);
  }

  document.querySelectorAll('[data-open-modal]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  successCloseBtn?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('open')) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitLabel!.textContent = 'Submitting...';
    submitSpinner!.style.display = 'block';
    submitBtn!.disabled = true;

    try {
      const data = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const json = await res.json();

      if (json.success) {
        form.style.display = 'none';
        successEl!.style.display = 'block';
      } else {
        submitLabel!.textContent = 'Submit Application';
        submitSpinner!.style.display = 'none';
        submitBtn!.disabled = false;
        alert('Something went wrong. Please try again or call us.');
      }
    } catch {
      submitLabel!.textContent = 'Submit Application';
      submitSpinner!.style.display = 'none';
      submitBtn!.disabled = false;
      alert('Something went wrong. Please try again or call us.');
    }
  });
</script>
