---
const logoURL = "https://www.jovie.com/app/uploads/2025/04/Jovie_TaglineLogo_NannySitters_CMYK-2-1536x730-min.png";
---

<nav
  style="
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: #1A475E;
    border-bottom: 1px solid #143A4E;
    height: 70px;
    display: flex;
    align-items: center;
  "
>
  <div
    class="container"
    style="
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    "
  >
    <a href="/" aria-label="Jovie of Ann Arbor — Home" style="display: flex; align-items: center; text-decoration: none;">
      <img
        src={logoURL}
        alt="Jovie — nannies + sitters"
        style="height: 36px; width: auto; object-fit: contain;"
        loading="eager"
      />
    </a>

    <button class="btn-primary" data-open-modal>
      Apply Now
    </button>
  </div>
</nav>
